#include <stdio.h>
int main()
{
    int n,s=0;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    for(int i=0;i<n;i++){
        for(int j=i;j<n;j++){
            s=0;
            for(int k=i;k<=j;k++){
                printf("%d ",a[k]);
              s+=a[k];
            }
            printf("sum =%d",s);
            printf("\n");
            
            
        }
    }

    return 0;
}
