#include <stdio.h>

int main()
{
    int n,s=0,t;
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    scanf("%d",&t);
    for(int i=0;i<n;i++){
        for(int j=i;j<n;j++){
            s=0;
            for(int k=i;k<=j;k++){
                s+=a[k];
            }
            if(s==t){
                for(int b=i;b<=j;b++){
                    printf("%d ",a[b]);
                }
            }
        }
    }
    return 0;
}
